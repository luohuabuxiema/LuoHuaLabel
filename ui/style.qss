/* LuoHuaLabel Dark Mode Dashboard Theme (暗黑仪表盘主题) */
/*
   Base Colors (基础色板):
   Background (主背景): #020617 (slate-950)
   Primary (次背景/面板): #0F172A (slate-900)
   Secondary (悬停/选中状态): #1E293B (slate-800)
   Border (边框): #334155 (slate-700)
   Text (主文本): #F8FAFC (slate-50)
   Accent/CTA (强调色/按钮): #22C55E (green-500)
   Muted Text (次要文本): #94A3B8 (slate-400)
*/

/* ---------------------------------------------------------
   全局基础设置
   --------------------------------------------------------- */
/* 主窗口与通用面板背景 */
QMainWindow, QWidget {
    background-color: #020617; /* 最深色背景 */
    color: #F8FAFC;            /* 亮白色文字 */
    font-family: "Fira Code", "Fira Sans", "Microsoft YaHei", sans-serif; /* 现代化字体 */
}

/* ---------------------------------------------------------
   工具栏与按钮 (顶部/左侧)
   --------------------------------------------------------- */
/* 工具栏容器 */
QToolBar {
    background-color: #0F172A;       /* 面板底色 */
    border-right: 1px solid #334155; /* 右侧分割线 */
    padding: 8px;                    /* 内边距 */
    spacing: 12px;                   /* 按钮间距 */
}

/* 工具栏普通按钮 */
QToolButton {
    background-color: transparent;   /* 默认透明背景 */
    border: 1px solid transparent;   /* 预留边框位置避免闪烁 */
    border-radius: 8px;              /* 圆角 */
    padding: 8px;
    color: #94A3B8;                  /* 默认灰色文字 */
    font-size: 13px;
    font-weight: 600;                /* 半粗体 */
}

/* 工具栏按钮 - 鼠标悬停状态 */
QToolButton:hover {
    background-color: #1E293B;       /* 浅一层背景 */
    color: #F8FAFC;                  /* 文字变亮 */
    border: 1px solid #334155;       /* 显现边框 */
}

/* 工具栏按钮 - 选中/激活状态 (如：正在使用该工具) */
QToolButton:checked {
    background-color: #1E293B;       /* 浅一层背景 */
    color: #22C55E;                  /* 强调绿色文字 */
    border: 1px solid #22C55E;       /* 强调绿色边框 */
}

/* ---------------------------------------------------------
   SAM 智能辅助专用按钮 (左下角)
   --------------------------------------------------------- */
/* SAM按钮 - 未选中状态 */
QToolButton#samAction {
    background-color: #0F172A;
    border: 2px solid #334155;       /* 加粗的边框 */
    border-radius: 8px;
    color: #94A3B8;
}

/* SAM按钮 - 选中状态（开启智能标注） */
QToolButton#samAction:checked {
    background-color: #22C55E;       /* 绿色高亮背景 */
    border: 2px solid #16a34a;       /* 更深的绿色边框 */
    color: #020617;                  /* 反色文字(深色)保证对比度 */
    font-weight: bold;
}

/* SAM按钮 - 选中时的悬停效果 */
QToolButton#samAction:checked:hover {
    background-color: #4ade80;       /* 稍微提亮的绿色 */
}

/* ---------------------------------------------------------
   停靠窗口 (右侧文件与类别列表)
   --------------------------------------------------------- */
/* 停靠窗口基础文本 */
QDockWidget {
    font-weight: bold;
    color: #F8FAFC;
}

/* 停靠窗口标题栏 */
QDockWidget::title {
    background: #0F172A;             /* 面板底色 */
    padding: 12px;
    border-bottom: 1px solid #334155;/* 底部边缘分割线 */
    color: #F8FAFC;
}

/* 列表控件容器 (文件列表/历史类别) */
QListWidget {
    background-color: #0F172A;
    border: 1px solid #334155;
    border-radius: 8px;
    color: #F8FAFC;
    padding: 4px;
    outline: 0;                      /* 移除系统默认的焦点虚线框 */
}

/* 列表中的每一项 */
QListWidget::item {
    padding: 6px 8px;
    border-radius: 4px;
    color: #cbd5e1;                  /* 略暗的文字颜色 */
}

/* 列表项 - 鼠标悬停 */
QListWidget::item:hover {
    background-color: #1E293B;       /* 悬停背景提亮 */
}

/* 列表项 - 选中状态 */
QListWidget::item:selected {
    background-color: #1E293B;
    color: #22C55E;                  /* 绿色高亮文字 */
    border-left: 4px solid #22C55E;  /* 左侧绿色指示条 */
}

/* 列表项处于编辑状态时生成的输入框 */
QListWidget QLineEdit {
    background-color: #1E293B;
    color: #F8FAFC;
    border: 1px solid #22C55E;       /* 绿色边框表示编辑中 */
    border-radius: 4px;
    padding: 2px 6px;
    margin: 0px;
    font-size: 13px;
    min-height: 24px;
}

/* ---------------------------------------------------------
   中央画板区域
   --------------------------------------------------------- */
/* 画布视图容器 */
QGraphicsView {
    background-color: #000000;       /* 纯黑背景，突出图片和标注 */
    border: 1px solid #334155;
    border-radius: 8px;
    margin: 8px;                     /* 与窗口边缘留白 */
}

/* ---------------------------------------------------------
   通用表单控件 (输入框与普通按钮)
   --------------------------------------------------------- */
/* 输入框与按钮通用基础样式 */
QLineEdit, QPushButton {
    padding: 8px 12px;
    border: 1px solid #334155;
    border-radius: 8px;
    background: #0F172A;
    color: #F8FAFC;
    font-weight: 500;
}

/* 输入框 - 获得焦点时 */
QLineEdit:focus {
    border: 1px solid #22C55E;       /* 绿色高亮边框 */
    background: #1E293B;             /* 背景提亮 */
}

/* 按钮 - 鼠标悬停时 */
QPushButton:hover {
    background: #1E293B;
    border: 1px solid #475569;
}

/* 按钮 - 鼠标按下时 */
QPushButton:pressed {
    background: #334155;             /* 按下时背景加深 */
}

/* ---------------------------------------------------------
   底部状态栏
   --------------------------------------------------------- */
/* 状态栏容器 */
QStatusBar {
    background-color: #0F172A;
    color: #94A3B8;                  /* 灰色次要信息文字 */
    border-top: 1px solid #334155;   /* 顶部边缘分割线 */
}

/* 状态栏内的文本标签 */
QStatusBar QLabel {
    color: #94A3B8;
    padding: 2px 8px;
    background: transparent;
}

/* ---------------------------------------------------------
   通用标签
   --------------------------------------------------------- */
/* 普通文本标签 (如：模式、状态提示等) */
QLabel {
    color: #cbd5e1;
    background: transparent;
}